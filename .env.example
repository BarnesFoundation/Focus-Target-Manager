# Focus Target Manager — local dev environment
# Copy to .env.local; values below match a dev box running Focus-Image-Resolver
# locally with auth disabled.

# Engine base URL. In prod this is the same origin as the UI (served by Caddy
# at engine.barnesfoc.us/manage), so leave empty to use the current origin.
VITE_ENGINE_BASE_URL=http://localhost:8000

# Azure AD app registration. Fill these in once the Focus-Target-Manager app
# is registered in the Barnes tenant. Same values that go into the engine's
# FOCUS_AZURE_TENANT_ID / FOCUS_AZURE_CLIENT_ID — the engine validates the
# token issued by this app.
VITE_AZURE_TENANT_ID=
VITE_AZURE_CLIENT_ID=

# Redirect URI registered for the app in Azure. In dev this is the Vite dev
# server's callback; in prod it's https://engine.barnesfoc.us/manage/auth/callback.
VITE_AZURE_REDIRECT_URI=http://localhost:5173/manage/auth/callback

# Optional: scope identifier for a custom API audience. Leave empty for a
# basic ID-token flow.
VITE_AZURE_SCOPE=
